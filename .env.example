# Copia este fichero a .env y rellena los valores. .env NO se sube al repo.

# OpenAI (obligatorio)
OPENAI_API_KEY=sk-...
# Modelo de chat: gpt-5 (demo) | gpt-5-mini (desarrollo/evals)
OPENAI_CHAT_MODEL=gpt-5-mini

# Proveedor de embeddings: openai | ollama
EMBEDDINGS_PROVIDER=openai

# Base de datos (el valor por defecto solo para desarrollo local)
POSTGRES_PASSWORD=agentpilot_dev

ASPNETCORE_ENVIRONMENT=Development
